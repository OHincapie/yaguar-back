meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "admin",
    "password": "admin123"
  }
}

script:after-response {
  const data = res.getBody();
  if (data.access_token) {
    bru.setEnvVar("authToken", data.access_token);
  }
}
